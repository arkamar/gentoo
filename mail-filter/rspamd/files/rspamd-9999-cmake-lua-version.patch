-	IF (NOT WITH_LIBLUA)
-		ProcessPackage(LIBLUA LIBRARY	"lua"
-				"lua-5.4"
-				LIB_SUFFIXES	"lua5.4"
-				INCLUDE lua.h INCLUDE_SUFFIXES
-				"include/lua-5.4"

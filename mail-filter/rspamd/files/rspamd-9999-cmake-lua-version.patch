-			IF (NOT WITH_LIBLUA)
-				ProcessPackage(LIBLUA LIBRARY	"lua"
-						"lua-5.1"
-						INCLUDE lua.h INCLUDE_SUFFIXES
-						"include/lua-5.1"
-						"include/lua5.1"
-						"include/lua51"
-						"include/lua"
-						ROOT ${LUA_ROOT}
-						MODULES lua51)
-			ENDIF()
-		ENDIF()
-	ENDIF()
+			MODULES lua)
 ENDIF(ENABLE_LUAJIT MATCHES "ON")
 
 IF(ENABLE_JEMALLOC MATCHES "ON" AND NOT SANITIZE)
